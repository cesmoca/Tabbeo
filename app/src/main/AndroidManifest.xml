<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" >

    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:name=".TabbeoApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/TabbeoAppTheme" >
        <activity
            android:name=".Activities.ActivitySplashScreen"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Activities.MainContainer.ActivityMainContainer"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="@string/title_activity_world_map" />
        <activity
            android:name=".Activities.Exercises.ActivityExercisePrevInfo"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="@string/title_activity_activity_pre_exercise" />
        <activity
            android:name=".Activities.Exercises.ActivityExerciseOnOffButton"
            android:configChanges="keyboardHidden"
            android:label="@string/title_activity_exercise">
        </activity>
        <activity
            android:name=".Activities.Exercises.ActivityExerciseSlideshow"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="@string/title_activity_exercise_tutorial_basic_concepts">
        </activity>
    </application>

</manifest>
