<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="TabbeoAppTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <!-- colorPrimary is used for coloring the Toolbar -->
        <item name="colorPrimary">@color/tabbeo_light_blue</item>
        <!-- colorPrimaryDark is used for coloring the status bar -->
        <item name="colorPrimaryDark">@color/tabbeo_dark_blue</item>
        <!-- colorAccent is used as the default divisor for colorControlActivated which is used to tint widgets -->
        <item name="colorAccent">@color/tabbeo_dark_green</item>

    </style>

    <style name="TabbeoDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:textColorPrimary">@color/tabbeo_light_blue</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="colorAccent">@color/tabbeo_dark_blue</item>
    </style>

</resources>