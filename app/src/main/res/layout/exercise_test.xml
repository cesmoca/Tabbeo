<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:background="#FFFFFF"
    tools:context=".Activities.Exercises.ActivityExerciseTest">

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:id="@+id/exercisetest_layout_header"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:text="-"
            android:textColor="#000000"
            android:layout_centerHorizontal="true"
            android:id="@+id/exercisetest_field_detectednote" />

        <com.tabbeo.Widgets.PitchPrecision
            android:id="@+id/exercisetest_drawview_noteaccuracy"
            android:layout_width="fill_parent"
            android:layout_below="@+id/exercisetest_field_detectednote"
            android:layout_height="35dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:text="Proc/s: "
            android:textColor="#000000"
            android:id="@+id/exercisetest_label_fftps"
            android:layout_alignParentLeft="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:text="30"
            android:textColor="#000000"
            android:id="@+id/exercisetest_field_pps"
            android:layout_alignParentTop="true"
            android:layout_toRightOf="@+id/exercisetest_label_fftps"
            android:layout_toEndOf="@+id/exercisetest_label_fftps" />

    </RelativeLayout>

    <com.tabbeo.Widgets.OnOffButton
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:id="@+id/exercisetest_button_onoff"
        android:layout_below="@+id/exercisetest_layout_header"
        android:layout_alignParentRight="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="#000000"
        android:id="@+id/exercisetest_field_tempo"
        android:layout_below="@+id/exercisetest_label_tempo"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="#000000"
        android:text="Tempo"
        android:id="@+id/exercisetest_label_tempo"
        android:layout_below="@+id/exercisetest_layout_header"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:text="Note"
        android:textColor="#000000"
        android:id="@+id/exercisetest_label_note"
        android:layout_alignBottom="@+id/exercisetest_button_onoff"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

    <RadioButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/exercisetest_radioButton_note"
        android:layout_alignTop="@+id/exercisetest_label_note"
        android:layout_toRightOf="@+id/exercisetest_label_note"
        android:textColor="#000000"
        android:layout_toEndOf="@+id/exercisetest_label_note" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="#000000"
        android:id="@+id/exercisetest_field_note"
        android:layout_alignTop="@+id/exercisetest_radioButton_note"
        android:layout_toRightOf="@+id/exercisetest_radioButton_note"
        android:layout_toEndOf="@+id/exercisetest_radioButton_note" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:text="Total points: "
        android:textColor="#000000"
        android:id="@+id/exercisetest_label_totalpoints"
        android:layout_alignTop="@+id/exercisetest_field_note"
        android:layout_centerHorizontal="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="#000000"
        android:id="@+id/exercisetest_field_totalpoints"
        android:layout_alignTop="@+id/exercisetest_label_totalpoints"
        android:layout_toRightOf="@+id/exercisetest_label_totalpoints"
        android:layout_toEndOf="@+id/exercisetest_label_totalpoints" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:text="Current note"
        android:textColor="#000000"
        android:id="@+id/exercisetest_label_currentnote"
        android:layout_below="@+id/exercisetest_radioButton_note"
        android:layout_alignLeft="@+id/exercisetest_radioButton_note"
        android:layout_alignStart="@+id/exercisetest_radioButton_note" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="Next note"
        android:textColor="#000000"
        android:id="@+id/exercisetest_label_nextnote"
        android:layout_above="@+id/exercisetest_field_nextnote"
        android:layout_toLeftOf="@+id/exercisetest_button_onoff"
        android:layout_toStartOf="@+id/exercisetest_button_onoff" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:textColor="#000000"
        android:text="1"
        android:id="@+id/exercisetest_field_currentnote"
        android:layout_below="@+id/exercisetest_label_currentnote"
        android:layout_alignLeft="@+id/exercisetest_label_currentnote"
        android:layout_alignStart="@+id/exercisetest_label_currentnote" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="#000000"
        android:id="@+id/exercisetest_field_nextnote"
        android:layout_alignTop="@+id/exercisetest_field_currentnote"
        android:layout_alignLeft="@+id/exercisetest_label_nextnote"
        android:layout_alignStart="@+id/exercisetest_label_nextnote" />

    <com.tabbeo.Widgets.ExerciseWidget
        android:id="@+id/exercisetest_fretboard"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_alignParentRight="true"
        android:layout_alignParentLeft="true"
        android:background="@color/tabbeo_light_blue"
        android:layout_below="@+id/exercisetest_field_currentnote"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
